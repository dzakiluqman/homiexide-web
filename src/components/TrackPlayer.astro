---
interface Props {
  title: string;
  author: string;
  cover: string;
  audioUrl: string;
}

const { title, author, cover, audioUrl } = Astro.props;
---

<div class="track-player flex gap-4 mb-6" data-audio={audioUrl}>
  <img src={cover} alt={title} class="w-24 h-24 rounded-xl object-cover border border-[#2a2a2a] shadow-lg" />

  <div class="flex-1 flex flex-col justify-center">
    <div class="flex items-center gap-3 mb-2">
      <button class="play-btn w-10 h-10 flex items-center justify-center bg-white rounded-full hover:scale-105 transition-transform">
        <svg class="w-5 h-5 text-black ml-1 play-icon" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
        <svg class="w-5 h-5 text-black hidden pause-icon" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
      </button>

      <div>
        <h3 class="text-[16px] font-bold text-white uppercase tracking-wide">{title}</h3>
        <p class="text-[13px] text-gray-400 font-medium">{author}</p>
      </div>
    </div>

    <div class="waveform-container w-full h-[40px] cursor-pointer bg-white/5 rounded-md"></div>
    
    <div class="flex justify-between items-center mt-1.5 px-1">
      <div class="flex gap-2">
        <button class="w-[22px] h-[22px] bg-[#d9d9d9]/10 hover:bg-[#d9d9d9]/30 rounded-[4px] flex items-center justify-center transition-colors cursor-pointer" title="Share">
          <svg class="w-3.5 h-3.5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
        </button>
        <button class="w-[22px] h-[22px] bg-[#d9d9d9]/10 hover:bg-[#d9d9d9]/30 rounded-[4px] flex items-center justify-center transition-colors cursor-pointer" title="Copy Link">
          <svg class="w-3.5 h-3.5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
        </button>
      </div>
      <span class="text-[10px] text-gray-500 font-medium">▶ 193</span>
    </div>
  </div>
</div>

<script>
  import WaveSurfer from 'wavesurfer.js';

  const players = document.querySelectorAll('.track-player');

  players.forEach(player => {
    const audioUrl = player.getAttribute('data-audio');
    const waveContainer = player.querySelector('.waveform-container');
    const playBtn = player.querySelector('.play-btn');
    const playIcon = player.querySelector('.play-icon');
    const pauseIcon = player.querySelector('.pause-icon');

    if (waveContainer && audioUrl) {
      const wavesurfer = WaveSurfer.create({
        container: waveContainer as HTMLElement,
        waveColor: '#4b5563', 
        progressColor: '#ffffff',
        barWidth: 2, 
        barGap: 2, 
        barRadius: 2, 
        height: 40, 
        cursorWidth: 0, 
      });

      wavesurfer.load(audioUrl);

      playBtn?.addEventListener('click', () => {
        wavesurfer.playPause();
      });

      wavesurfer.on('play', () => {
        playIcon?.classList.add('hidden');
        pauseIcon?.classList.remove('hidden');
      });

      wavesurfer.on('pause', () => {
        playIcon?.classList.remove('hidden');
        pauseIcon?.classList.add('hidden');
      });
    }
  });
</script>