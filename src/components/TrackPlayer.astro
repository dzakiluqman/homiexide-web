---
interface Props {
  title: string;
  author: string;
  cover: string;
  audioUrl: string;
  lyrics?: string;
}

const { title, author, cover, audioUrl, lyrics } = Astro.props;
---

<div 
  class="track-player flex gap-4 mb-6" 
  data-audio={audioUrl} 
  data-title={title} 
  data-author={author} 
  data-cover={cover}
  data-lyrics={lyrics ?? ''}
>
  <img src={cover} alt={title} class="w-24 h-24 rounded-xl object-cover border border-[#2a2a2a] shadow-lg" />

  <div class="flex-1 flex flex-col justify-center">
    <div class="flex items-center gap-3 mb-2">
      <button class="play-btn w-10 h-10 flex items-center justify-center bg-white rounded-full hover:scale-105 transition-transform">
        <svg class="w-5 h-5 text-black ml-1 play-icon" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
        <svg class="w-5 h-5 text-black hidden pause-icon" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
      </button>

      <div>
        <h3 class="text-[16px] font-bold text-white uppercase tracking-wide">{title}</h3>
        <p class="text-[13px] text-gray-400 font-medium">{author}</p>
      </div>
    </div>

    <div class="waveform-container w-full h-[40px] cursor-pointer bg-white/5 rounded-md"></div>
  </div>
</div>

<script>
  import WaveSurfer from 'wavesurfer.js';

  declare global {
    interface Window {
      ybrPlaylist: any[];
      currentTrackIndex: number;
    }
  }

  document.addEventListener('astro:page-load', () => {
    if (!window.ybrPlaylist) {
      window.ybrPlaylist = []; 
    }

    const players = document.querySelectorAll('.track-player');
    const audioEngine = document.getElementById('global-audio-engine') as HTMLAudioElement;

    // 1. Broadcast waktu dari mesin global
    if (audioEngine && !audioEngine.getAttribute('data-sync-attached')) {
      audioEngine.addEventListener('timeupdate', () => {
        window.dispatchEvent(new Event('ybr-engine-timeupdate'));
      });
      audioEngine.setAttribute('data-sync-attached', 'true');
    }

    players.forEach((player) => {
      const audioUrl = player.getAttribute('data-audio');
      const title = player.getAttribute('data-title');
      const author = player.getAttribute('data-author');
      const cover = player.getAttribute('data-cover');
      const lyrics = player.getAttribute('data-lyrics');
      
      const waveContainer = player.querySelector('.waveform-container') as HTMLElement;
      const playBtn = player.querySelector('.play-btn') as HTMLButtonElement;
      const playIcon = player.querySelector('.play-icon') as SVGSVGElement;
      const pauseIcon = player.querySelector('.pause-icon') as SVGSVGElement;

      if (waveContainer && audioUrl) {
        
        setTimeout(() => {
          
          waveContainer.innerHTML = ''; 

          const wavesurfer = WaveSurfer.create({
            container: waveContainer,
            waveColor: '#4b5563', 
            progressColor: '#ffffff',
            barWidth: 2, 
            barGap: 2, 
            barRadius: 2, 
            height: 40, 
            cursorWidth: 0, 
          });

          wavesurfer.setVolume(0);

          wavesurfer.load(audioUrl);

          let trackIndex = window.ybrPlaylist.findIndex(t => t.audioUrl === audioUrl);

          if (trackIndex === -1) {
            trackIndex = window.ybrPlaylist.length;
            window.ybrPlaylist.push({
              index: trackIndex,
              title,
              author,
              cover,
              audioUrl,
              lyrics: lyrics ?? '',
              wavesurfer,
              hasBottomPlayerListeners: false
            });
          } else {
            // Update referensi wavesurfer dengan instance yang baru digambar
            window.ybrPlaylist[trackIndex].wavesurfer = wavesurfer;
            window.ybrPlaylist[trackIndex].lyrics = lyrics ?? window.ybrPlaylist[trackIndex].lyrics ?? '';
          }

          const updateIconUI = () => {
            const isEnginePlaying = audioEngine && !audioEngine.paused;
            if (window.currentTrackIndex === trackIndex && (wavesurfer.isPlaying() || isEnginePlaying)) {
              playIcon?.classList.add('hidden');
              pauseIcon?.classList.remove('hidden');
            } else {
              playIcon?.classList.remove('hidden');
              pauseIcon?.classList.add('hidden');
            }
          };

          // Saat gelombang selesai dirender, cek sinkronisasi
          wavesurfer.on('ready', () => {
            wavesurfer.setVolume(0); 
            if (window.currentTrackIndex === trackIndex && audioEngine) {
              const duration = audioEngine.duration || 1;
              wavesurfer.seekTo(audioEngine.currentTime / duration);
              if (!audioEngine.paused) {
                wavesurfer.play().catch(() => {});
              }
              updateIconUI();
            }
          });

          // Sinkronisasi paksa setiap detak mesin audio
          const handleTimeUpdate = () => {
            if (window.currentTrackIndex === trackIndex && audioEngine) {
              const audioTime = audioEngine.currentTime;
              const waveTime = wavesurfer.getCurrentTime();
              const duration = audioEngine.duration || 1;

              if (Math.abs(audioTime - waveTime) > 0.1) {
                try { wavesurfer.seekTo(audioTime / duration); } catch(e) {}
              }

              if (!audioEngine.paused && !wavesurfer.isPlaying()) {
                wavesurfer.play().catch(() => {});
              }
              
              updateIconUI();
            }
          };

          window.addEventListener('ybr-engine-timeupdate', handleTimeUpdate);

          // Bersihkan memory saat pindah page
          document.addEventListener('astro:before-swap', () => {
            window.removeEventListener('ybr-engine-timeupdate', handleTimeUpdate);
            // Hancurkan instance wavesurfer lama sebelum hilang
            try { wavesurfer.destroy(); } catch(e) {}
          }, { once: true });

          wavesurfer.on('play', updateIconUI);
          wavesurfer.on('pause', updateIconUI);
          window.addEventListener('ybr-global-ui-sync', updateIconUI);

          playBtn?.addEventListener('click', () => {
            if (window.currentTrackIndex === trackIndex && audioEngine) {
              if (audioEngine.paused) {
                audioEngine.play();
                wavesurfer.play().catch(()=>{});
              } else {
                audioEngine.pause();
                wavesurfer.pause();
              }
            } else {
              window.dispatchEvent(new CustomEvent('ybr-play-track', { 
              detail: { 
                index: trackIndex, 
                lyrics: lyrics ?? '' 
              } 
            }));
            }
          });

        }, 150); // Akhir dari setTimeout
        
      }
    });
  });
</script>