---
import FeatureCard from '../components/FeatureCard.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Homiexide</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous">
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="relative min-h-screen bg-[#09090b] text-white selection:bg-purple-900/50">
		
		<div class="absolute top-[-20%] left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-white/5 rounded-full blur-[150px] pointer-events-none"></div>

		<header class="relative z-50 px-8 pt-8">
			<div class="max-w-[1400px] mx-auto flex items-center justify-between">
				<a href="/" class="text-3xl font-black tracking-tighter text-white flex items-center gap-1">
					HOMIEXIDE
				</a>

				<nav class="hidden md:flex items-center gap-2 px-8 py-3 rounded-[2rem] border border-white/10 bg-white/5 backdrop-blur-md">
					<a href="/" class="px-4 py-1 text-[15px] font-bold text-white hover:text-gray-300 transition-colors">Home</a>
					
					<div class="relative">
						<button id="menu-btn" class="px-4 py-1 text-[15px] font-bold text-white hover:text-gray-300 transition-colors flex items-center gap-1">
							Menu
						</button>
						
						<ul id="dropdown-menu" class="hidden absolute top-full left-1/2 -translate-x-1/2 mt-4 p-2 shadow-2xl bg-[#121214] border border-[#2a2a2a] rounded-2xl w-56 backdrop-blur-3xl z-10">
							<li><a href="/ybr" class="block px-4 py-2.5 text-sm font-medium text-gray-300 hover:bg-white/10 hover:text-white rounded-xl transition-all">Young Boys Records</a></li>
							<li><a href="/skins" class="block px-4 py-2.5 text-sm font-medium text-gray-300 hover:bg-white/10 hover:text-white rounded-xl transition-all">Skin Catalogue</a></li>
							<li><a href="/modpacks" class="block px-4 py-2.5 text-sm font-medium text-gray-300 hover:bg-white/10 hover:text-white rounded-xl transition-all">GTA SA Modpack</a></li>
						</ul>
					</div>

					<a href="/about" class="px-4 py-1 text-[15px] font-bold text-white hover:text-gray-300 transition-colors">About</a>
				</nav>

				<div class="w-[120px] hidden md:block"></div>
			</div>
		</header>

        <script>
			const menuBtn = document.getElementById('menu-btn');
			const dropdownMenu = document.getElementById('dropdown-menu');

			// Toggle dropdown saat diklik
			menuBtn?.addEventListener('click', (e) => {
				e.stopPropagation();
				dropdownMenu?.classList.toggle('hidden');
			});

			// Tutup dropdown jika klik di luar area menu
			document.addEventListener('click', (e) => {
				if (!menuBtn?.contains(e.target as Node) && !dropdownMenu?.contains(e.target as Node)) {
					dropdownMenu?.classList.add('hidden');
				}
			});
		</script>
	</body>
</html>

<style is:global>
	body {
		font-family: 'Montserrat', sans-serif;
	}
</style>