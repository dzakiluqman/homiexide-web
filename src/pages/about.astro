                        </svg>
                    </a>
                    <a href="https://youtube.com/@look-at-us?si=26VZAqOPRmhygB2V" target="_blank" aria-label="YouTube" class="text-gray-400 hover:text-[#FF0000] hover:scale-110 transition-all duration-300">
                        <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                        </svg>
                    </a>
                    <a href="https://www.tiktok.com/@homiexide151?_r=1&_t=ZS-954022n0J65" target="_blank" aria-label="TikTok" class="text-gray-400 hover:text-white hover:scale-110 transition-all duration-300">
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z" />
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <div>
            <h2 class="text-2xl font-bold text-white mb-8 tracking-wide">We builded</h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                
                <div class="border border-white/10 bg-transparent rounded-[1.5rem] p-8 flex flex-col justify-between h-full">
                    <div>
                        <div class="flex items-center gap-3 mb-4">
                            <span class="w-3.5 h-3.5 rounded-full bg-[#5b21b6]"></span> <h3 class="text-[15px] font-bold text-white tracking-wide">Boulevard Westfield</h3>
                        </div>
                        <p class="text-[13px] text-gray-400 leading-relaxed">
                            The epicenter of the GTA SA Multiplayer scene. We provide a space to share Roleplay experiences. If you're looking for a family to grow up together with in the virtual worlds, this is your home.
                        </p>
                    </div>
                    <div class="flex justify-end mt-12">
                        <button class="bg-[#3b0764] hover:bg-[#5b21b6] text-white text-[13px] font-medium px-8 py-2.5 rounded-lg transition-colors">
                            Details
                        </button>
                    </div>
                </div>

                <div class="border border-white/10 bg-transparent rounded-[1.5rem] p-8 flex flex-col justify-between h-full">
                    <div>
                        <div class="flex items-center gap-3 mb-4">
                            <span class="w-3.5 h-3.5 rounded-full bg-[#854d0e]"></span> <h3 class="text-[15px] font-bold text-white tracking-wide">Money Stackin High</h3>
                        </div>
                        <p class="text-[13px] text-gray-400 leading-relaxed">
                            The epicenter of the GTA SA Multiplayer scene. We provide a space to share Roleplay experiences. If you're looking for a family to grow up together with in the virtual worlds, this is your home.
                        </p>
                    </div>
                    <div class="flex justify-end mt-12">
                        <button class="bg-[#713f12] hover:bg-[#854d0e] text-white text-[13px] font-medium px-8 py-2.5 rounded-lg transition-colors">
                            Details
                        </button>
                    </div>
                </div>

                <div class="border border-white/10 bg-transparent rounded-[1.5rem] p-8 flex flex-col justify-between h-full">
                    <div>
                        <div class="flex items-center gap-3 mb-4">
                            <span class="w-3.5 h-3.5 rounded-full bg-[#1d4ed8]"></span> <h3 class="text-[15px] font-bold text-white tracking-wide">Florencia 13</h3>
                        </div>
                        <p class="text-[13px] text-gray-400 leading-relaxed">
                            The epicenter of the GTA SA Multiplayer scene. We provide a space to share Roleplay experiences. If you're looking for a family to grow up together with in the virtual worlds, this is your home.
                        </p>
                    </div>
                    <div class="flex justify-end mt-12">
                        <button class="bg-[#1e3a8a] hover:bg-[#1d4ed8] text-white text-[13px] font-medium px-8 py-2.5 rounded-lg transition-colors">
                            Details
                        </button>
                    </div>
                </div>

            </div>
        </div>

    </main>
</Layout>