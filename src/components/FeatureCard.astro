---
interface Props {
	iconName: string;
	title: string;
	description: string;
	buttonText: string;
}

const { iconName, title, description, buttonText } = Astro.props;

// Menentukan warna icon
const iconColor = 
	iconName === 'YBR' ? 'text-[#c026d3]' :
	iconName === 'Skins' ? 'text-[#dc2626]' :
	iconName === 'Modpacks' ? 'text-[#4f46e5]' :
	'text-[#4f5bbe]'; // Community

// Menentukan warna background tombol
const buttonClass = 
	iconName === 'YBR' ? 'bg-[#8B0068] hover:bg-[#6b0050]' :
	iconName === 'Skins' ? 'bg-[#990000] hover:bg-[#730000]' :
	iconName === 'Modpacks' ? 'bg-[#310073] hover:bg-[#20004d]' :
	'bg-[#4F5BBE] hover:bg-[#3d479e]';

// Menentukan warna GLARE (cahaya blur) di background saat di-hover
const glareColor = 
	iconName === 'YBR' ? 'bg-[#c026d3]' :
	iconName === 'Skins' ? 'bg-[#dc2626]' :
	iconName === 'Modpacks' ? 'bg-[#4f46e5]' :
	'bg-[#4f5bbe]';

// Menentukan warna BORDER card saat di-hover agar senada dengan cahayanya
const hoverBorder = 
	iconName === 'YBR' ? 'hover:border-[#c026d3]/50' :
	iconName === 'Skins' ? 'hover:border-[#dc2626]/50' :
	iconName === 'Modpacks' ? 'hover:border-[#4f46e5]/50' :
	'hover:border-[#4f5bbe]/50';
---

<div class={`group relative flex flex-col h-full p-7 rounded-2xl border border-[#2a2a2a] bg-[#111111] transition-all duration-500 overflow-hidden ${hoverBorder} hover:-translate-y-1`}>
	
	<div class={`absolute -top-10 -right-10 w-36 h-36 rounded-full blur-[45px] opacity-0 group-hover:opacity-30 transition-opacity duration-500 pointer-events-none ${glareColor}`}></div>

	<div class="relative z-10 flex flex-col h-full">
		<div class="flex items-center gap-3 mb-4">
			<svg class={`w-5 h-5 transition-transform duration-500 group-hover:scale-110 ${iconColor}`} fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
				{iconName === 'Community' && <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" />}
				{iconName === 'YBR' && <path d="M12 14c1.66 0 2.99-1.34 2.99-3L15 5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z" />}
				{iconName === 'Skins' && <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-5.5-2.5l7.51-3.49L17.5 6.5 9.99 9.99 6.5 17.5zm5.5-6.6c.61 0 1.1.49 1.1 1.1s-.49 1.1-1.1 1.1-1.1-.49-1.1-1.1.49-1.1 1.1-1.1z" />}
				{iconName === 'Modpacks' && <path d="M20.5 11H19V7c0-1.1-.9-2-2-2h-4V3.5C13 2.12 11.88 1 10.5 1S8 2.12 8 3.5V5H4c-1.1 0-1.99.9-1.99 2v3.8H3.5c1.49 0 2.7 1.21 2.7 2.7s-1.21 2.7-2.7 2.7H2V20c0 1.1.9 2 2 2h3.8v-1.5c0-1.49 1.21-2.7 2.7-2.7 1.49 0 2.7 1.21 2.7 2.7V22H17c1.1 0 2-.9 2-2v-4h1.5c1.38 0 2.5-1.12 2.5-2.5S21.88 11 20.5 11z" />}
			</svg>
			<h3 class="text-[15px] font-bold text-white tracking-wide">{title}</h3>
		</div>

		<p class="text-[13px] text-gray-300 leading-relaxed flex-grow font-medium">
			{description}
		</p>

		<div class="flex justify-end mt-8">
			<button class={`px-5 py-2 rounded-xl text-xs font-bold text-white transition-all ${buttonClass}`}>
				{buttonText}
			</button>
		</div>
	</div>
</div>