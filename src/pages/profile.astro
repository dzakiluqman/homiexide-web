---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Profile">
    <main class="w-full min-h-screen flex items-center justify-center px-8">
        <div class="w-full max-w-[500px] bg-[#111111]/60 border border-white/10 rounded-[3rem] p-12 text-center">
            <div class="w-24 h-24 bg-purple-600 rounded-full mx-auto mb-6 flex items-center justify-center text-3xl font-bold text-white">
                <span id="initial">H</span>
            </div>
            <h1 id="prof-username" class="text-2xl font-black text-white mb-2">Username</h1>
            <p id="prof-role" class="text-purple-400 uppercase tracking-widest text-xs font-bold mb-8">Role</p>
            
            <button id="logout-btn" class="w-full py-4 bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white border border-red-500/20 rounded-2xl font-bold transition-all">
                Sign Out / Logout
            </button>
        </div>
    </main>
</Layout>

<script>
    document.addEventListener('astro:page-load', () => {
        const session = JSON.parse(localStorage.getItem('user_session') || '{}');
        if (!session.username) { window.location.href = '/talents/login'; return; }

        document.getElementById('prof-username')!.innerText = session.username;
        document.getElementById('prof-role')!.innerText = session.role;
        document.getElementById('initial')!.innerText = session.username.charAt(0).toUpperCase();

        document.getElementById('logout-btn')?.addEventListener('click', () => {
            localStorage.removeItem('user_session');
            window.location.href = '/talents/login';
        });
    });
</script>